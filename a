-- HBE_REPORT HOOK (Spam Blocker & Spoof)
--=============================================================================
local lastHBE = 0
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if not checkcaller() and method == "FireServer" and tostring(self) == "HBE_Report" then
        -- 1 FPS LAGINI ENGELLEYİCİ SPAM KORUMASI: Sadece 0.45 saniyede bir geçmesine izin ver
        if tick() - lastHBE < 0.45 then
            return nil -- Fazla gelen tüm Spam'leri (FPS düşürenleri) sunucuya gitmeden çöpten at
        end
        lastHBE = tick()
        
        local payload = args[1]
        if type(payload) == "table" then
            -- ANTICHEAT BYPASS: Biz bacağımızı 50 yapsak bile sunucu standart boyut (1x) zannedecek!
            if type(payload["Left Leg"]) == "table" then payload["Left Leg"].Size = Vector3.new(1, 2, 1) end
            if type(payload["Right Leg"]) == "table" then payload["Right Leg"].Size = Vector3.new(1, 2, 1) end
            if type(payload["Left Arm"]) == "table" then payload["Left Arm"].Size = Vector3.new(1, 2, 1) end
            if type(payload["Right Arm"]) == "table" then payload["Right Arm"].Size = Vector3.new(1, 2, 1) end
            if type(payload["Torso"]) == "table" then payload["Torso"].Size = Vector3.new(2, 2, 1) end
            if type(payload["Head"]) == "table" then payload["Head"].Size = Vector3.new(2, 1, 1) end
            if type(payload["HumanoidRootPart"]) == "table" then payload["HumanoidRootPart"].Size = Vector3.new(2, 2, 1) end
            
            return oldNamecall(self, payload)
        end
    end
    
    return oldNamecall(self, ...)
end)

